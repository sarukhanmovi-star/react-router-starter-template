{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "env": {
    "NODE_OPTIONS": "--experimental-modules"
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
